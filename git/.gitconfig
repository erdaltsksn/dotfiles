[include]
    path = ~/.dotsecret/.gitconfig

[help]
    autocorrect = 1

[core]
    excludesfile = ~/.dotfiles/git/.gitignore
    pager = diff-so-fancy | less --tabs=4 -RFX

[init]
    defaultBranch = main

[commit]
    template = ~/.dotfiles/git/.gittemplate
    gpgsign = true

[pull]
    ff = only
